			<div class="wpb_wrapper">
				<h1 style="color: #fdb515;text-align: left" class="vc_custom_heading vc_do_custom_heading vc_custom_1726070906857" >Ratified Specification</h1><h4 style="color: #ffffff;text-align: left" class="vc_custom_heading vc_do_custom_heading vc_custom_1728672251823" >The RISC-V open-standard instruction set architecture (ISA) defines the fundamental guidelines for designing and implementing RISC-V processors.</h4><a class="nectar-button large regular extra-color-1  regular-button"  role="button" style="margin-top: 25px; color: #0a0a0a; "  href="https://docs.riscv.org/" data-color-override="false" data-hover-color-override="false" data-hover-text-color-override="#fff"><span>VIEW RATIFIED SPECS</span></a><a class="nectar-button large regular extra-color-3  regular-button"  role="button" style="margin-left: 25px;color: #ffffff; "  href="/specifications/development/" data-color-override="false" data-hover-color-override="false" data-hover-text-color-override="#fff"><span>SPECS UNDER DEVELOPMENT</span></a>
			</div> 
		</div>
	</div> 

	<div  class="vc_col-sm-6 wpb_column column_container vc_column_container col no-extra-padding inherit_tablet inherit_phone flex_gap_desktop_10px "  data-padding-pos="all" data-has-bg-color="false" data-bg-color="" data-bg-opacity="1" data-animation="" data-delay="0" >
